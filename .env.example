APP_NAME="RAGForge"
APP_VERSION="0.1.0"
APP_ENV="development"

FILE_MAX_SIZE_MB=10
FILE_DEFAULT_CHUNK_SIZE=1048576
FILE_ALLOWED_EXTENSIONS=["pdf", "txt", "docx"]
FILE_ALLOWED_MIME_TYPES=["application/pdf", "text/plain", "application/vnd.openxmlformats-officedocument.wordprocessingml.document"]

UPLOAD_DIR="storage/uploads"
PROJECT_DOCUMENTS_DIR="documents"

OPENAI_API_KEY="your_openai_api_key_here"

MONGODB_URL="mongodb://localhost:27007"
MONGODB_DATABASE="ragforge"

# =========================
# LLM Configuration
# =========================

LLM_PROVIDER="fake"
LLM_DEFAULT_MODEL="fake-ragforge-model"
LLM_TEMPERATURE=0.2
LLM_MAX_OUTPUT_TOKENS=512
LLM_TIMEOUT_SECONDS=60

# Used only when LLM_PROVIDER="openai_compatible"
OPENAI_API_KEY=""
OPENAI_BASE_URL=""
