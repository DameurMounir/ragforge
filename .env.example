APP_NAME="RAGForge"
APP_VERSION="0.1.0"
APP_ENV="development"

# =========================
# File Upload Configuration
# =========================
FILE_MAX_SIZE_MB=10
FILE_DEFAULT_CHUNK_SIZE=1048576
FILE_ALLOWED_EXTENSIONS=["pdf", "txt", "docx"]
FILE_ALLOWED_MIME_TYPES=["application/pdf", "text/plain", "application/vnd.openxmlformats-officedocument.wordprocessingml.document"]

UPLOAD_DIR="storage/uploads"
PROJECT_DOCUMENTS_DIR="documents"

# =========================
# MongoDB Configuration
# =========================
MONGO_INITDB_ROOT_USERNAME="ragforge"
MONGO_INITDB_ROOT_PASSWORD="ragforge_password_change_me"
MONGODB_URL="mongodb://localhost:27007"
MONGODB_DATABASE="ragforge"

# =========================
# LLM Configuration
# =========================
LLM_PROVIDER="fake"
LLM_DEFAULT_MODEL="fake-ragforge-model"
LLM_TEMPERATURE=0.2
LLM_MAX_OUTPUT_TOKENS=512
LLM_TIMEOUT_SECONDS=60

# Used only when LLM_PROVIDER="openai_compatible".
# Keep empty for fake provider validation.
OPENAI_API_KEY=""
OPENAI_BASE_URL=""

# =========================
# Embedding Configuration
# =========================
EMBEDDING_PROVIDER="fake"
EMBEDDING_MODEL="text-embedding-3-small"
EMBEDDING_VECTOR_SIZE=1536
EMBEDDING_BATCH_SIZE=32
FAKE_EMBEDDING_MODEL="fake-embedding-model"

# Used only when EMBEDDING_PROVIDER="openai_compatible".
# Keep empty for fake provider validation.
EMBEDDING_OPENAI_API_KEY=""
EMBEDDING_OPENAI_BASE_URL=""

# =========================
# Vector DB Configuration
# =========================
# Keep qdrant for Branch 16-19 behavior.
# Use pgvector to test Branch 21 backend.
VECTOR_DB_PROVIDER="qdrant"

# Generic vector indexing settings.
VECTOR_DB_COLLECTION_NAME="ragforge_chunks"
VECTOR_DB_VECTOR_SIZE=1536
VECTOR_DB_DISTANCE="cosine"

# =========================
# Qdrant Provider Configuration
# =========================
# server = Docker Qdrant service
# local = local embedded Qdrant, useful for tests only
QDRANT_MODE="server"
QDRANT_URL="http://localhost:6333"
QDRANT_API_KEY=""
QDRANT_LOCAL_PATH="storage/vector_db/qdrant"

QDRANT_COLLECTION_NAME="ragforge_chunks"
QDRANT_VECTOR_SIZE=1536
QDRANT_DISTANCE="cosine"
QDRANT_PREFER_GRPC=false

# =========================
# Semantic Search Configuration
# =========================
SEARCH_DEFAULT_LIMIT=5
SEARCH_MAX_LIMIT=20
# Optional. Leave commented unless you want a global score threshold.
# SEARCH_MIN_SCORE=
SEARCH_INCLUDE_TEXT_DEFAULT=true
SEARCH_INCLUDE_METADATA_DEFAULT=true

# =========================
# Branch 18 RAG Answer Configuration
# =========================
RAG_ANSWER_DEFAULT_LIMIT=5
RAG_ANSWER_MAX_CONTEXT_CHARS=8000
RAG_ANSWER_INCLUDE_SOURCES_DEFAULT=true
RAG_ANSWER_INCLUDE_EVIDENCE_DEFAULT=true
RAG_ANSWER_DEBUG_PROMPT_DEFAULT=false

# =========================
# Branch 19 Retrieval Quality / Citation Stability
# =========================
RAG_RETRIEVAL_CANDIDATE_LIMIT=30
RAG_RETRIEVAL_MIN_SCORE=0.25
RAG_MAX_CHUNKS_PER_ASSET=3
RAG_ENABLE_SOURCE_DEDUP=true
RAG_ENABLE_DOMINANT_ASSET=true
RAG_DOMINANT_ASSET_SCORE_GAP=0.08
RAG_DOMINANT_ASSET_MIN_CHUNKS=2
RAG_ENABLE_CITATION_VALIDATION=true

# =========================
# PostgreSQL / PgVector-ready Database Settings
# =========================
POSTGRES_USER="ragforge"
POSTGRES_PASSWORD="ragforge_password_change_me"
POSTGRES_HOST="localhost"
POSTGRES_PORT=5433
POSTGRES_DB="ragforge"
POSTGRES_ECHO=false
POSTGRES_POOL_SIZE=5
POSTGRES_MAX_OVERFLOW=10
POSTGRES_POOL_TIMEOUT=30
POSTGRES_POOL_RECYCLE=1800

# =========================
# PgVector Provider — Branch 21 v4
# =========================
# One Alembic-managed table. No dynamic project tables.
PGVECTOR_TABLE_NAME="vector_records"

# EMBEDDING_VECTOR_SIZE is the source of truth.
# Optional: set PGVECTOR_VECTOR_SIZE only when you intentionally want an
# explicit equality guard. If set, it must equal EMBEDDING_VECTOR_SIZE.
# PGVECTOR_VECTOR_SIZE=1536

# Supported distance values: cosine | euclid | dot
PGVECTOR_DISTANCE="cosine"

# Supported index types: hnsw | ivfflat
PGVECTOR_INDEX_TYPE="hnsw"

# Supported index expression vector types: vector | halfvec
# - vector supports approximate indexes up to 2000 dimensions.
# - halfvec supports approximate indexes up to 4000 dimensions.
PGVECTOR_INDEX_VECTOR_TYPE="vector"

# HNSW settings.
PGVECTOR_HNSW_M=16
PGVECTOR_HNSW_EF_CONSTRUCTION=64
PGVECTOR_HNSW_EF_SEARCH=40

# IVFFLAT settings.
PGVECTOR_IVFFLAT_LISTS=100
PGVECTOR_IVFFLAT_PROBES=10

# For IVFFLAT, set a positive threshold so the index is created after enough rows.
# HNSW can be created before data, so 0 is acceptable for the default HNSW mode.
PGVECTOR_INDEX_MIN_RECORDS=0
PGVECTOR_AUTO_CREATE_INDEX=true
PGVECTOR_CREATE_EXTENSION_ON_STARTUP=true

# =========================
# Branch 22 Observability / Prometheus Metrics
# =========================
METRICS_ENABLED=true
METRICS_PATH="/metrics"
METRICS_INCLUDE_IN_SCHEMA=false
METRICS_SKIP_PATHS=["/metrics", "/docs", "/redoc", "/openapi.json", "/favicon.ico"]

