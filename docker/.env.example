# =========================
# MongoDB
# =========================
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=admin

MONGODB_DATABASE=ragforge
MONGODB_URL=mongodb://admin:admin@localhost:27007/ragforge?authSource=admin


# =========================
# PostgreSQL / PgVector
# =========================
POSTGRES_USER=ragforge
POSTGRES_PASSWORD=ragforge_password_change_me
POSTGRES_DB=ragforge

# Important:
# Because FastAPI/Alembic run from WSL host, use localhost.
# Docker maps local port 5433 -> container port 5432.
POSTGRES_HOST=localhost
POSTGRES_PORT=5433

POSTGRES_ECHO=false
POSTGRES_POOL_SIZE=5
POSTGRES_MAX_OVERFLOW=10
POSTGRES_POOL_TIMEOUT=30
POSTGRES_POOL_RECYCLE=1800